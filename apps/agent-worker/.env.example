# Volle Agent Worker Environment

# LLM provider (OpenAI-compatible: OpenRouter, OpenAI, etc.)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

