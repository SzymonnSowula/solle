{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Volle",
  "version": "0.1.0",
  "identifier": "com.volle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Volle",
        "width": 420,
        "height": 340,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Volle AI",
    "copyright": "Copyright (c) 2026 Volle AI",
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png"
    ]
  }
}
