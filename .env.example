# Environment variables for Volle (Solli)
# Copy this file to .env.local and fill in the values

# ElevenLabs - Voice AI
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_AGENT_ID=your_elevenlabs_agent_id_here
ELEVENLABS_WS_URL=wss://api.elevenlabs.io/v1/agent/stream

# OpenAI - LLM backend
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Ollama - Local LLM fallback (set USE_OLLAMA=true to enable)
USE_OLLAMA=false
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# Google APIs - Calendar & Gmail
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Database
DATABASE_URL=postgresql://solli:solli_dev_password@localhost:5432/solli

# Redis
REDIS_URL=redis://default:solli_dev_password@localhost:6379

# Solana Blockchain
# SECURITY: Default to devnet to prevent accidental mainnet transactions
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet
SOLANA_WALLET_ADDRESS=your_solana_wallet_address_here
ANCHOR_PROGRAM_ID=CnrBFrZP2kwZWYbev3xzTJsDJGK6bTe1HBaNtQ55JSxx

# Workers
WORKER_BROWSER_URL=http://localhost:3002
WORKER_GOOGLE_URL=http://localhost:3003

# Worker Authentication (shared secret for inter-service calls)
WORKER_AUTH_SECRET=your_worker_secret_here

# Voice
ELEVENLABS_WEBHOOK_SECRET=your_webhook_secret_here

# Environment
NODE_ENV=development
LOG_LEVEL=debug
