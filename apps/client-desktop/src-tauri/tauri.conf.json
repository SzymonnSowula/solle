{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Volle",
  "version": "0.1.0",
  "identifier": "com.volle.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Volle",
        "width": 420,
        "height": 340,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "resizable": false,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Volle AI",
    "copyright": "Copyright (c) 2026 Volle AI",
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png"
    ],
    "windows": {
      "wix": {
        "language": "pl-PL",
        "upgradeCode": "{E5A2C4B1-8F3D-4A6E-9B0C-1D2E3F4A5B6C}",
        "bannerPath": "icons/wix-banner.bmp",
        "dialogImagePath": "icons/wix-dialog.bmp"
      },
      "nsis": {
        "installMode": "perMachine",
        "languages": ["Polish", "English"],
        "displayLanguageSelector": true
      },
      "certificateThumbprint": null,
      "signCommand": null
    }
  }
}
